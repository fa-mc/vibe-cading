        "free":  {"radial": 0.15, "axial": 0.25},
        "slip":  {"radial": 0.05, "axial": 0.25, "slot": 0.10},
        "press": {"radial": 0.04, "axial": 0.25}
    },
    "my_saturn_resin": {
        "free":  {"radial": 0.05, "axial": 0.05},
        "slip":  {"radial": 0.03, "axial": 0.05},
        "press": {"radial": 0.02, "axial": 0.05}
    }
}
