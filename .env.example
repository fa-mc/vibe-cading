# vibe-cading — example environment configuration.
#
# Copy this file to `.env` and customise as needed. The runtime reads `.env`
# via a small standard-library parser (see models/print_settings.py and
# models/lego/constants.py); no external dependencies are required.
#
# Every variable below is optional — defaults are baked into the codebase.

# -----------------------------------------------------------------------------
# Global manufacturing default
# -----------------------------------------------------------------------------
# Selects the active tolerance / fit profile from machine_profiles.json (and
# any overrides in the untracked machine_profiles_user.json). Used as the
# fallback when a model/method does not receive an explicit `profile=` kwarg.
VIBE_MACHINE_PROFILE="fdm_standard"

# -----------------------------------------------------------------------------
# Lego Technic dimensional overrides (models/lego/constants.py)
# -----------------------------------------------------------------------------
# Recommended diameter for 3D-printed Technic-style pin holes (mm).
# Default 4.85 — tune to your printer/material's effective hole shrink.
PIN_HOLE_PRINTED="4.85"

# Inner concave corner fillet radius applied to Technic-axle profiles (mm).
DEFAULT_CORNER_RADIUS="0.4"

# End-face chamfer length applied to Technic-axle ends to ease insertion (mm).
DEFAULT_LEAD_IN="0.3"

# -----------------------------------------------------------------------------
# GitHub CLI authentication
# -----------------------------------------------------------------------------
# Personal access token used by `gh` for issue/PR operations from this
# workspace. The agent loads this from .env before invoking `gh`; do NOT run
# `gh auth login` interactively.
GH_TOKEN=""
