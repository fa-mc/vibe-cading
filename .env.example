# vibe-cading — example environment configuration.
#
# Copy this file to `.env` and customise as needed. The runtime reads `.env`
# via a small standard-library parser (see vibe_cading/print_settings.py and
# vibe_cading/lego/constants.py); no external dependencies are required.
#
# Every variable below is optional — defaults are baked into the codebase.

# -----------------------------------------------------------------------------
# Global manufacturing default
# -----------------------------------------------------------------------------
# Selects the active tolerance / fit profile from print_profiles.json (and
# any overrides in the untracked print_profiles_user.json). Used as the
# fallback when a model/method does not receive an explicit `profile=` kwarg.
#
# To calibrate the active profile for your printer, run
# `python3 tools/calibrate.py slip` after printing the Lego axle gauge —
# this writes the measured value into print_profiles_user.json without
# touching the shipped defaults. See README.md > Print Tolerances & Calibration.
PRINT_PROFILE="fdm_standard"

# -----------------------------------------------------------------------------
# Lego Technic dimensional overrides (vibe_cading/lego/constants.py)
# -----------------------------------------------------------------------------
# Inner concave corner fillet radius applied to Technic-axle profiles (mm).
DEFAULT_CORNER_RADIUS="0.4"

# End-face chamfer length applied to Technic-axle ends to ease insertion (mm).
DEFAULT_LEAD_IN="0.3"

# Note: the Technic cross axle-hole dimensions (AXLE_HOLE_TIP_TO_TIP /
# AXLE_HOLE_ARM_WIDTH) are fixed real-Lego nominals in
# vibe_cading/lego/constants.py and are NOT env-overridable.  To tune the
# printed axle fit for your machine, calibrate your ToleranceProfile's
# slip.radial in print_profiles_user.json — see docs/lego-technic.md >
# Tuning Tolerances.

# -----------------------------------------------------------------------------
# GitHub CLI authentication
# -----------------------------------------------------------------------------
# Personal access token used by `gh` for issue/PR operations from this
# workspace. The agent loads this from .env before invoking `gh`; do NOT run
# `gh auth login` interactively.
GH_TOKEN=""
