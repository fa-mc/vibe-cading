{
    "name": "CadQuery Dev",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "bernhard-42.ocp-cad-viewer"
            ]
        }
    },
    "forwardPorts": [
        3939
    ],
    "remoteUser": "root",
    "mounts": [
        "source=${localEnv:SSH_AUTH_SOCK},target=/ssh-agent,type=bind"
    ],
    "remoteEnv": {
        "SSH_AUTH_SOCK": "/ssh-agent",
        "PYTHONPATH": "/workspaces/cad/models"
    },
    "postCreateCommand": "git config --global --add safe.directory /workspaces/cad"
}