{
    "name": "CadQuery Dev",
    "build": {
        "dockerfile": "Dockerfile"
        // To pin the user to a non-1000 host UID at build time, add:
        // "args": { "USER_UID": "1001", "USER_GID": "1001" }
        // On the common path this is unnecessary: the default is UID 1000 and
        // VS Code's updateRemoteUserUID (below) re-stamps to the host UID.
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "bernhard-42.ocp-cad-viewer",
                "Anthropic.claude-code",
                "SimonSiefke.svg-preview"
            ]
        }
    },
    "forwardPorts": [
        3939
    ],
    "remoteUser": "vscode",
    "updateRemoteUserUID": true,
    "mounts": [
        "source=${localEnv:HOME}/.ssh,target=/tmp/host-ssh,type=bind,readonly",
        // If you override USERNAME (default "vscode") via build args, also update
        // "remoteUser" above and the /home/<user>/.claude target below — neither
        // can interpolate the Dockerfile ARG. Overriding only USER_UID/USER_GID
        // (the common non-1000-host case) needs no change here.
        "source=${localEnv:HOME}${localEnv:USERPROFILE}/.claude,target=/home/vscode/.claude,type=bind,consistency=cached",
        // Per-project credentials isolation: override ONLY .credentials.json with a
        // project-scoped host file (seeded by initializeCommand below) while the rest
        // of ~/.claude (settings, memory, history) stays shared. Prevents the
        // single-use OAuth-refresh race where concurrent devcontainers sharing one
        // host ~/.claude evict each other's token and force constant re-logins.
        // This nested mount MUST stay AFTER the broad ~/.claude mount above so the
        // more-specific path wins. Caveat: keyed on ${localWorkspaceFolderBasename},
        // so it isolates across DIFFERENT projects but NOT across two concurrent
        // clones of THIS repo (same basename) — swap in a more unique suffix if you
        // run two vibe-cading clones at once.
        "source=${localEnv:HOME}${localEnv:USERPROFILE}/.claude-creds/${localWorkspaceFolderBasename}/.credentials.json,target=/home/vscode/.claude/.credentials.json,type=bind,consistency=cached",
        "source=${localEnv:HOME}${localEnv:USERPROFILE}/.gemini,target=/home/vscode/.gemini,type=bind,consistency=cached"
    ],
    // Seed the per-project credentials file on first create: make the dir, then
    // copy the shared token in once (or touch an empty file if none exists yet) so
    // the nested bind mount above always has a real host file to bind. Idempotent.
    "initializeCommand": "mkdir -p ${localEnv:HOME}${localEnv:USERPROFILE}/.claude-creds/${localWorkspaceFolderBasename} && { [ -f ${localEnv:HOME}${localEnv:USERPROFILE}/.claude-creds/${localWorkspaceFolderBasename}/.credentials.json ] || cp ${localEnv:HOME}${localEnv:USERPROFILE}/.claude/.credentials.json ${localEnv:HOME}${localEnv:USERPROFILE}/.claude-creds/${localWorkspaceFolderBasename}/.credentials.json 2>/dev/null || touch ${localEnv:HOME}${localEnv:USERPROFILE}/.claude-creds/${localWorkspaceFolderBasename}/.credentials.json; }",
    "remoteEnv": {
        "SSH_AUTH_SOCK": "/ssh-agent",
        "PYTHONPATH": "/workspaces/vibe-cading"
    },
    "postCreateCommand": "git config --global --add safe.directory /workspaces/vibe-cading && sudo chown -R \"$(id -u):$(id -g)\" /workspaces/vibe-cading && mkdir -p \"$HOME/.ssh\" && cp -a /tmp/host-ssh/. \"$HOME/.ssh/\" && chmod 700 \"$HOME/.ssh\" && find \"$HOME/.ssh\" -maxdepth 1 -type f ! -name '*.pub' -exec chmod 600 {} + && find \"$HOME/.ssh\" -maxdepth 1 -name '*.pub' -exec chmod 644 {} +"
}
